{
  "name": "Neu",
  "author": "sfox38",
  "version": "1.2",
  "harvest_version": 1,
  "description": "Neumorphism inspired theme with physical-feeling controls. Dual box-shadows create extruded and inset surfaces. Grey-only palette.",
  "has_renderer": true,
  "renderer_settings": ["show_icon", "show_name", "widget_border"],
  "capabilities": {
    "fan":          { "display_modes": ["on-off", "continuous", "stepped", "cycle"] },
    "input_number": { "display_modes": ["slider", "buttons"] },
    "input_select": { "display_modes": ["pills", "dropdown"] },
    "select":       { "display_modes": ["pills", "dropdown"] },
    "light":        { "features": ["brightness", "color_temp", "rgb"] },
    "climate":      { "features": ["hvac_modes", "presets", "fan_mode", "swing_mode"] },
    "cover":        { "features": ["position", "tilt"] },
    "media_player": { "features": ["transport", "volume", "source"] }
  },
  "variables": {
    "--hrv-card-min-width":          "280px",

    "--hrv-color-primary":           "#6b7280",
    "--hrv-color-primary-dim":       "#d1d5db",
    "--hrv-color-on-primary":        "#ffffff",
    "--hrv-color-accent":            "#6b7280",

    "--hrv-color-surface":           "#e0e5ec",
    "--hrv-color-surface-alt":       "#e0e5ec",
    "--hrv-color-surface-tint":      "#e0e5ec",
    "--hrv-color-surface-on":        "#e0e5ec",
    "--hrv-color-border":            "transparent",
    "--hrv-color-divider":           "rgba(0,0,0,0.06)",

    "--hrv-color-text":              "#374151",
    "--hrv-color-text-secondary":    "#6b7280",
    "--hrv-color-text-inverse":      "#ffffff",
    "--hrv-color-icon":              "#4b5563",

    "--hrv-color-state-on":          "#4b5563",
    "--hrv-color-state-off":         "#9ca3af",
    "--hrv-color-state-unavailable": "#d1d5db",
    "--hrv-color-warning":           "#9ca3af",
    "--hrv-color-error":             "#6b7280",
    "--hrv-color-success":           "#6b7280",

    "--hrv-color-overlay":           "rgba(0,0,0,0.6)",
    "--hrv-color-overlay-text":      "#ffffff",

    "--hrv-card-background":         "#e0e5ec",
    "--hrv-card-radius":             "20px",
    "--hrv-card-shadow":             "4px 4px 8px #b8bec7, -4px -4px 8px #ffffff",
    "--hrv-card-padding":            "18px",
    "--hrv-card-border":             "none",
    "--hrv-card-backdrop-filter":    "none",

    "--hrv-radius-s":                "6px",
    "--hrv-radius-m":                "12px",
    "--hrv-radius-l":                "20px",
    "--hrv-icon-size":               "22px",
    "--hrv-font-family":             "system-ui, -apple-system, sans-serif",
    "--hrv-transition-speed":        "250ms",

    "--hrv-ex-neu-bg":               "#e0e5ec",
    "--hrv-ex-neu-shadow-light":     "#ffffff",
    "--hrv-ex-neu-shadow-dark":      "#b8bec7",
    "--hrv-ex-neu-convex":           "4px 4px 8px #b8bec7, -4px -4px 8px #ffffff",
    "--hrv-ex-neu-concave":          "inset 2px 2px 5px #b8bec7, inset -2px -2px 5px #ffffff",
    "--hrv-ex-neu-convex-sm":        "2px 2px 4px #b8bec7, -2px -2px 4px #ffffff",
    "--hrv-ex-neu-concave-sm":       "inset 1px 1px 3px #b8bec7, inset -1px -1px 3px #ffffff",
    "--hrv-ex-neu-flat":             "none",

    "--hrv-block-header-shadow":     "0 2px 4px #b8bec7, inset 0 1px 0 #ffffff",
    "--hrv-block-header-bg":         "#dce1e8",
    "--hrv-card-shadow-inner":       "inset 2px 2px 5px #b8bec7, inset -2px -2px 5px #ffffff"
  },
  "dark_variables": {
    "--hrv-color-primary":           "#9ca3af",
    "--hrv-color-primary-dim":       "#374151",
    "--hrv-color-on-primary":        "#1f2937",

    "--hrv-color-surface":           "#2d2d3a",
    "--hrv-color-surface-alt":       "#2d2d3a",
    "--hrv-color-surface-tint":      "#2d2d3a",
    "--hrv-color-surface-on":        "#2d2d3a",
    "--hrv-color-border":            "transparent",
    "--hrv-color-divider":           "rgba(255,255,255,0.06)",

    "--hrv-color-text":              "#d1d5db",
    "--hrv-color-text-secondary":    "#9ca3af",
    "--hrv-color-text-inverse":      "#1f2937",
    "--hrv-color-icon":              "#9ca3af",

    "--hrv-color-state-on":          "#d1d5db",
    "--hrv-color-state-off":         "#4b5563",
    "--hrv-color-state-unavailable": "#374151",
    "--hrv-color-warning":           "#9ca3af",
    "--hrv-color-error":             "#9ca3af",
    "--hrv-color-success":           "#9ca3af",

    "--hrv-color-overlay":           "rgba(0,0,0,0.7)",

    "--hrv-card-background":         "#2d2d3a",
    "--hrv-card-shadow":             "none",

    "--hrv-ex-neu-bg":               "#2d2d3a",
    "--hrv-ex-neu-shadow-light":     "#404050",
    "--hrv-ex-neu-shadow-dark":      "#1a1a24",
    "--hrv-ex-neu-convex":           "4px 4px 8px #1a1a24, -4px -4px 8px #404050",
    "--hrv-ex-neu-concave":          "inset 2px 2px 5px #1a1a24, inset -2px -2px 5px #404050",
    "--hrv-ex-neu-convex-sm":        "2px 2px 4px #1a1a24, -2px -2px 4px #404050",
    "--hrv-ex-neu-concave-sm":       "inset 1px 1px 3px #1a1a24, inset -1px -1px 3px #404050",
    "--hrv-ex-neu-flat":             "none",

    "--hrv-block-header-shadow":     "0 2px 4px #1a1a24, inset 0 1px 0 #404050",
    "--hrv-block-header-bg":         "#282836",
    "--hrv-card-shadow-inner":       "inset 2px 2px 5px #1a1a24, inset -2px -2px 5px #404050"
  }
}
