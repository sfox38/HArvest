    "--hrv-card-font-family": "inherit",
    "--hrv-card-font-size": "14px",
    "--hrv-card-min-width": "240px",
    "--hrv-card-max-width": "360px",
    "--hrv-name-color": "#1a1a1a",
    "--hrv-name-font-size": "14px",
    "--hrv-name-font-weight": "600",
    "--hrv-name-margin-bottom": "12px",
    "--hrv-icon-size": "28px",
