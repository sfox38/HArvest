{
  "name": "Shrooms",
  "author": "Inspired by Mushroom Cards by Paul Bottein (https://github.com/piitaya/lovelace-mushroom)",
  "version": "1.0.0",
  "harvest_version": 1,
  "renderer_pack": true,
  "pack_settings": ["layout"],
  "capabilities": {
    "fan": {
      "display_modes": [
        "on-off",
        "continuous",
        "stepped",
        "cycle"
      ]
    },
    "input_number": {
      "display_modes": [
        "slider",
        "buttons"
      ]
    },
    "light": {
      "features": [
        "brightness",
        "color_temp",
        "rgb"
      ]
    },
    "climate": {
      "features": [
        "hvac_modes",
        "presets",
        "fan_mode",
        "swing_mode"
      ]
    },
    "cover": {
      "features": [
        "position",
        "tilt"
      ]
    },
    "media_player": {
      "features": [
        "transport",
        "volume",
        "source"
      ]
    }
  },
  "variables": {
    "--hrv-card-min-width": "260px",
    "--hrv-color-primary": "#ff9800",
    "--hrv-color-primary-dim": "rgba(255,152,0,0.12)",
    "--hrv-color-on-primary": "#ffffff",
    "--hrv-color-surface": "#ffffff",
    "--hrv-color-surface-alt": "#f5f5f5",
    "--hrv-color-border": "rgba(0,0,0,0.06)",
    "--hrv-color-text": "#212121",
    "--hrv-color-text-secondary": "#757575",
    "--hrv-color-text-inverse": "#ffffff",
    "--hrv-color-icon": "#757575",
    "--hrv-color-state-on": "#ff9800",
    "--hrv-color-state-off": "#bdbdbd",
    "--hrv-color-state-unavailable": "#e0e0e0",
    "--hrv-color-warning": "#ff9800",
    "--hrv-color-error": "#f44336",
    "--hrv-color-success": "#4caf50",
    "--hrv-card-radius": "12px",
    "--hrv-card-shadow": "none",
    "--hrv-card-padding": "12px",
    "--hrv-card-background": "#ffffff",
    "--hrv-card-border": "1px solid rgba(0,0,0,0.10)",
    "--hrv-icon-size": "24px",
    "--hrv-font-family": "system-ui, -apple-system, 'Roboto', sans-serif",
    "--hrv-transition-speed": "280ms",
    "--hrv-ex-shroom-icon-size": "36px",
    "--hrv-ex-shroom-icon-bg-opacity": "0.2",
    "--hrv-ex-shroom-slider-height": "42px",
    "--hrv-ex-shroom-slider-radius": "12px",
    "--hrv-ex-shroom-spacing": "12px",
    "--hrv-ex-shroom-btn-bg": "rgba(0,0,0,0.05)",
    "--hrv-ex-shroom-btn-bg-active": "rgba(0,0,0,0.10)",
    "--hrv-ex-shroom-slider-track": "rgba(255,255,255,0.55)",
    "--hrv-ex-shroom-light": "#ff9800",
    "--hrv-ex-shroom-switch": "#2196f3",
    "--hrv-ex-shroom-fan": "#4caf50",
    "--hrv-ex-shroom-climate": "#ff5722",
    "--hrv-ex-shroom-cover": "#5389ec",
    "--hrv-ex-shroom-media": "#e91e63",
    "--hrv-ex-shroom-sensor": "#03a9f4",
    "--hrv-ex-shroom-binary": "#8bc34a",
    "--hrv-ex-shroom-input": "#00bcd4",
    "--hrv-ex-shroom-timer": "#673ab7",
    "--hrv-ex-shroom-remote": "#607d8b",
    "--hrv-ex-shroom-weather": "#ff9800",
    "--hrv-ex-shroom-action": "#9c27b0"
  },
  "dark_variables": {
    "--hrv-color-primary": "#ffb74d",
    "--hrv-color-primary-dim": "rgba(255,183,77,0.15)",
    "--hrv-color-on-primary": "#1a1a1a",
    "--hrv-color-surface": "#2d2d2d",
    "--hrv-color-surface-alt": "#383838",
    "--hrv-color-border": "rgba(255,255,255,0.08)",
    "--hrv-color-text": "#e0e0e0",
    "--hrv-color-text-secondary": "#9e9e9e",
    "--hrv-color-text-inverse": "#1a1a1a",
    "--hrv-color-icon": "#9e9e9e",
    "--hrv-color-state-on": "#ffb74d",
    "--hrv-color-state-off": "#616161",
    "--hrv-color-state-unavailable": "#424242",
    "--hrv-color-error": "#ef5350",
    "--hrv-card-background": "#2d2d2d",
    "--hrv-card-shadow": "none",
    "--hrv-card-border": "1px solid rgba(255,255,255,0.10)",
    "--hrv-ex-shroom-btn-bg": "rgba(255,255,255,0.08)",
    "--hrv-ex-shroom-btn-bg-active": "rgba(255,255,255,0.15)",
    "--hrv-ex-shroom-slider-track": "rgba(0,0,0,0.40)",
    "--hrv-ex-shroom-light": "#ffb74d",
    "--hrv-ex-shroom-switch": "#64b5f6",
    "--hrv-ex-shroom-fan": "#81c784",
    "--hrv-ex-shroom-climate": "#ff8a65",
    "--hrv-ex-shroom-cover": "#ce93d8",
    "--hrv-ex-shroom-media": "#f48fb1",
    "--hrv-ex-shroom-sensor": "#4fc3f7",
    "--hrv-ex-shroom-binary": "#aed581",
    "--hrv-ex-shroom-input": "#5389ec",
    "--hrv-ex-shroom-timer": "#b39ddb",
    "--hrv-ex-shroom-remote": "#90a4ae",
    "--hrv-ex-shroom-weather": "#ffb74d",
    "--hrv-ex-shroom-action": "#ce93d8"
  }
}