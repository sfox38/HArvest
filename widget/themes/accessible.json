  "dark_variables": {
    "--hrv-card-background-color": "#000000",
    "--hrv-card-color": "#ffffff",
    "--hrv-card-border": "2px solid #ffffff",
    "--hrv-card-accent-color": "#6699ff",
    "--hrv-name-color": "#ffffff",
    "--hrv-icon-color-on": "#6699ff",
    "--hrv-icon-color-off": "#a0a0a0",
    "--hrv-state-on-color": "#ffffff",
    "--hrv-state-off-color": "#a0a0a0",
    "--hrv-state-unavailable-color": "#767676",
    "--hrv-toggle-background-color-on": "#6699ff",
    "--hrv-toggle-background-color-off": "#767676",
    "--hrv-slider-track-color": "#767676",
    "--hrv-slider-fill-color": "#6699ff",
    "--hrv-slider-thumb-color": "#6699ff",
    "--hrv-error-background-color": "#3b0000",
    "--hrv-error-color": "#ffaaaa"
  }
