{
  "name": "Accessible",
  "author": "HArvest Contributors",
  "version": "1.0",
  "harvest_version": 1,
  "variables": {
    "--hrv-card-background-color": "#ffffff",
    "--hrv-card-color": "#000000",
    "--hrv-card-accent-color": "#0047ab",
    "--hrv-card-border-radius": "4px",
    "--hrv-card-border": "2px solid #000000",
    "--hrv-card-box-shadow": "none",
    "--hrv-card-padding": "16px",
    "--hrv-card-font-family": "inherit",
    "--hrv-card-font-size": "16px",
    "--hrv-card-min-width": "240px",
    "--hrv-card-max-width": "400px",
    "--hrv-name-color": "#000000",
    "--hrv-name-font-size": "16px",
    "--hrv-name-font-weight": "700",
    "--hrv-name-margin-bottom": "14px",
    "--hrv-icon-size": "32px",
    "--hrv-icon-color-on": "#0047ab",
    "--hrv-icon-color-off": "#595959",
    "--hrv-state-on-color": "#000000",
    "--hrv-state-off-color": "#595959",
    "--hrv-state-unavailable-color": "#767676",
    "--hrv-state-font-size": "14px",
    "--hrv-toggle-background-color-on": "#0047ab",
    "--hrv-toggle-background-color-off": "#595959",
    "--hrv-toggle-border-radius": "4px",
    "--hrv-toggle-width": "52px",
    "--hrv-toggle-height": "28px",
    "--hrv-toggle-transition-duration": "0ms",
    "--hrv-slider-track-color": "#595959",
    "--hrv-slider-fill-color": "#0047ab",
    "--hrv-slider-thumb-color": "#0047ab",
    "--hrv-slider-thumb-size": "24px",
    "--hrv-slider-height": "6px",
    "--hrv-slider-border-radius": "0px",
    "--hrv-stale-indicator-display": "block",
    "--hrv-stale-indicator-color": "#b45309",
    "--hrv-stale-indicator-size": "20px",
    "--hrv-stale-overlay-opacity": "0.6",
    "--hrv-error-background-color": "#fff0f0",
    "--hrv-error-color": "#9b1c1c",
    "--hrv-error-font-size": "14px",
    "--hrv-companion-icon-size": "22px",
    "--hrv-companion-gap": "10px"
